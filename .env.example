# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — add it to .gitignore immediately.

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Create a Personal Access Token at: https://github.com/settings/tokens
# Scopes needed: repo, pull_requests (read + write for posting reviews later)
GITHUB_TOKEN=ghp_your_token_here

# This secret is used to verify that webhook payloads actually come from GitHub
# (not a random attacker sending fake events). Set any random string here,
# then paste the SAME string into your GitHub webhook settings.
GITHUB_WEBHOOK_SECRET=your_random_secret_here

# ─── Gemini (Week 5) ──────────────────────────────────────────────────────────
# Get free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# ─── PostgreSQL (Week 7) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ai_reviewer
